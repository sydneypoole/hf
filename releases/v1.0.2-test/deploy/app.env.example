# Application runtime .env mounted into the container as /app/.env.
# Safe default: copied as-is, the app stays in install mode because DB_HOST is empty and INSTALLED=false.

# Database connection
DB_HOST=
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=hongfu

# Installation / runtime state
# Set INSTALLED=true only after DB_* and JWT_SECRET are real values.
INSTALLED=false
JWT_SECRET=replace-this-before-production
DEBUG=false

# Optional bootstrap fields written by the setup wizard
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SECRET_KEY=

# Optional payment fields written by the setup wizard or settings page
PAY_PID=
PAY_KEY=
USDT_NODE=
