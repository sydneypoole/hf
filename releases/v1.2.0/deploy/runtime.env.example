# Docker Compose variables for the GHCR image deployment.
# Replace IMAGE_REF with your real GHCR image address before running.
IMAGE_REF=ghcr.io/sydneypoole/hf:v1.2.0
CONTAINER_NAME=hongfu
HTTP_BIND=0.0.0.0
HTTP_PORT=80
TZ=Asia/Shanghai

# Persist the setup wizard output file generated inside the container.
# This path is resolved relative to deploy/docker-compose.ghcr.yml.
# Create it before first start: mkdir -p deploy/data && touch deploy/data/hongfu.env
HF_ENV_FILE=./data/hongfu.env
